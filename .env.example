# CTFd
CTFD_URL=https://ctf.example.com
CTFD_TOKEN=ctfd_your_api_token_here

# API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.masterjie.eu.cc/v1
GEMINI_API_KEY=

# OpenAI-compatible gateway (Pydantic / azure provider path)
AZURE_OPENAI_ENDPOINT=https://api.masterjie.eu.cc/v1
AZURE_OPENAI_API_KEY=sk-...

# Lingxu Event CTF (optional)
# Cookie must contain sessionid. If csrftoken exists in your browser, you can keep it too.
PLATFORM=
PLATFORM_URL=
LINGXU_EVENT_ID=
LINGXU_COOKIE=
